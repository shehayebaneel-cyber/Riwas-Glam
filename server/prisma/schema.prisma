// Riwa's Glam — single-salon booking + management backend.
// Production: PostgreSQL on Neon. `url` is the pooled connection (app runtime);
// `directUrl` is the unpooled connection Prisma uses for migrations / db push.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  emoji     String   @default("")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  services  Service[]
  addOns    AddOn[]
}

model Service {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  durationMin Int      @default(30)
  price       Float    @default(0)
  materialCost Float   @default(0) // est. product/material cost per service — feeds profit
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  staff       Staff[]  @relation("ServiceStaff") // the specialists who perform this service
  favoritedBy Customer[] @relation("CustomerFavorites")
  appointments Appointment[]
  products    ServiceProduct[] // the inventory items this service consumes (its "recipe")
}

// An inventory item the salon stocks (foundation, gel, wax…).
model Product {
  id           Int      @id @default(autoincrement())
  name         String
  brand        String   @default("")
  category     String   @default("")
  supplier     String   @default("")
  barcode      String   @default("")
  unit         String   @default("unit") // unit | ml | g | …
  costPrice    Float    @default(0) // what the salon pays
  sellingPrice Float    @default(0) // retail price if resold
  quantity     Float    @default(0) // current stock on hand
  minQuantity  Float    @default(0) // low-stock threshold
  expiryDate   String   @default("") // YYYY-MM-DD or ""
  location     String   @default("")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  movements    StockMovement[]
  usedBy       ServiceProduct[]
}

// A stock change (received, used, corrected) — the inventory history log.
model StockMovement {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String   // RECEIVE | USE | ADJUST
  quantity  Float    // signed delta (+ received, − used)
  note      String   @default("")
  createdAt DateTime @default(now())
  @@index([productId])
}

// Links a service to the products it consumes, and how much of each — the "recipe".
// Drives auto-deduction on completion and the service's material cost.
model ServiceProduct {
  id        Int     @id @default(autoincrement())
  serviceId Int
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Float   @default(1)
  @@unique([serviceId, productId])
}

// A gallery item shown on the Gallery page — photo, video, or before/after.
model GalleryItem {
  id        Int      @id @default(autoincrement())
  type      String   @default("IMAGE") // IMAGE | VIDEO | BEFOREAFTER
  url       String   @default("") // image, video URL, or the "after" image
  beforeUrl String   @default("") // the "before" image (BEFOREAFTER only)
  category  String   @default("")
  caption   String   @default("")
  serviceId Int? // link to a service for the "Book this look" button
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// A training course offered by the academy (lash, makeup…). Managed in admin.
model Course {
  id          Int      @id @default(autoincrement())
  title       String
  image       String   @default("")
  description String   @default("")
  duration    String   @default("") // e.g. "3 days", "1–3 days"
  price       Float    @default(0)
  includes    String   @default("[]") // JSON array of strings (what's included)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// A bundle of services sold as one (Bridal Package, Glow Package…).
model Package {
  id           Int      @id @default(autoincrement())
  title        String
  image        String   @default("")
  description  String   @default("")
  price        Float    @default(0)
  durationMin  Int      @default(60)
  serviceIds   String   @default("[]") // JSON array of included service ids (for display)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  appointments Appointment[]
}

// A salon location. One default branch today; ready for more.
model Branch {
  id           Int      @id @default(autoincrement())
  name         String
  address      String   @default("")
  phone        String   @default("")
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  staff        Staff[]
  appointments Appointment[]
}

// A customer account (self-service booking history, favourites, profile).
model Customer {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  phone        String   @default("")
  passwordHash String
  points         Int    @default(0) // spendable loyalty balance
  lifetimePoints Int    @default(0) // total ever earned — drives membership tier
  birthday     String   @default("") // YYYY-MM-DD (or MM-DD) for birthday rewards
  notes        String   @default("") // private notes the salon keeps
  tags         String   @default("[]") // JSON array of labels: VIP, Bride, Student, Influencer…
  createdAt    DateTime @default(now())
  appointments Appointment[]
  favorites    Service[] @relation("CustomerFavorites")
  reviews      Review[]
  redemptions  RewardRedemption[]
  photos       CustomerPhoto[]
}

// A before/after (or reference) photo the salon keeps on a customer's profile.
model CustomerPhoto {
  id         String   @id @default(cuid())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  url        String
  label      String   @default("")
  kind       String   @default("PHOTO") // PHOTO | BEFORE | AFTER | DOCUMENT
  createdAt  DateTime @default(now())
}

// A signed consent form (tattoo, botox, facial…) captured on-device.
model ConsentForm {
  id           String   @id @default(cuid())
  customerId   Int
  formType     String   @default("")
  customerName String   @default("")
  signatureUrl String   @default("") // signature image (data URL)
  body         String   @default("") // the consent text that was agreed to
  signedAt     DateTime @default(now())
  @@index([customerId])
}

// A loyalty reward a customer has redeemed with points — shown to staff in-salon.
model RewardRedemption {
  id         String   @id @default(cuid())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rewardName String
  cost       Int      @default(0)
  status     String   @default("ISSUED") // ISSUED | USED
  createdAt  DateTime @default(now())
}

// A digital gift card sold on the site (mock payment). Redeemed in-salon by the
// manager against a customer's bill.
model GiftCard {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  initialValue   Float
  balance        Float
  purchaserName  String   @default("")
  purchaserEmail String   @default("")
  recipientName  String   @default("")
  message        String   @default("")
  status         String   @default("ACTIVE") // PENDING | ACTIVE | REDEEMED | VOID
  paymentId      String?  @unique // linked Payment; the code stays PENDING until it is PAID
  paymentMethod  String   @default("CASH") // CASH | WHISH (future: CARD | BANK)
  paymentStatus  String   @default("PENDING") // PENDING | PAID | FAILED | CANCELLED
  customerId     Int?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
}

// A unified payment record — the single source of truth for money owed and paid,
// across bookings and gift cards (and future product orders). One model means a
// new method (card, bank) later is just a new `method` value + a provider branch;
// the checkout endpoints and the rest of the schema don't change.
model Payment {
  id            String    @id @default(cuid())
  reference     String    @unique // customer-facing ref, e.g. RG-7F3K-9Q2M
  kind          String    // BOOKING | GIFTCARD
  method        String    // CASH | WHISH   (future: CARD | BANK)
  status        String    @default("PENDING") // PENDING | PAID | FAILED | CANCELLED | REFUNDED
  amount        Float     @default(0)
  currency      String    @default("USD")
  appointmentId Int?      @unique // set when kind = BOOKING
  giftCardId    Int?      @unique // set when kind = GIFTCARD
  customerName  String    @default("")
  customerEmail String    @default("")
  customerPhone String    @default("")
  provider      String    @default("") // gateway used, e.g. "whish"
  providerTxnId String    @default("") // gateway transaction id (Whish)
  providerRef   String    @default("") // our order/collect id shared with the gateway
  providerData  String    @default("") // JSON of the last gateway payload (audit)
  meta          String    @default("{}") // JSON payload used to fulfil the purchase on PAID
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([status])
  @@index([kind])
}

// A promotional discount code applied at checkout.
model PromoCode {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  type          String   @default("PERCENT") // PERCENT | FIXED
  value         Float    @default(0)
  minSpend      Float    @default(0)
  maxUses       Int      @default(0) // 0 = unlimited
  usedCount     Int      @default(0)
  firstTimeOnly Boolean  @default(false)
  birthdayOnly  Boolean  @default(false)
  startsAt      String   @default("") // YYYY-MM-DD
  expiresAt     String   @default("")
  isActive      Boolean  @default(true)
  description   String   @default("")
  createdAt     DateTime @default(now())
}

// A record of every notification the system tried to send (audit + debugging).
model NotificationLog {
  id        Int      @id @default(autoincrement())
  channel   String   @default("EMAIL") // EMAIL | WHATSAPP | SMS
  to        String   @default("")
  event     String   @default("")
  subject   String   @default("")
  body      String   @default("")
  status    String   @default("PENDING") // SENT | FAILED | SKIPPED
  error     String   @default("")
  createdAt DateTime @default(now())
  @@index([createdAt])
}

// Simple key/value settings store the manager controls (gift-card config,
// site content, etc.).
model Setting {
  key   String @id
  value String @default("")
}

// A message on the internal team board (shared, most-recent-first).
model InternalMessage {
  id        String   @id @default(cuid())
  author    String   @default("")
  body      String
  createdAt DateTime @default(now())
  @@index([createdAt])
}

// Monthly performance target for a staff member.
model StaffGoal {
  id                 Int      @id @default(autoincrement())
  staffId            Int
  month              String // YYYY-MM
  revenueTarget      Float    @default(0)
  appointmentsTarget Int      @default(0)
  createdAt          DateTime @default(now())
  @@unique([staffId, month])
}

// A stock supplier the salon buys inventory from.
model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @default("")
  email     String   @default("")
  website   String   @default("")
  note      String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// A purchase order to a supplier; receiving it restocks the linked products.
model PurchaseOrder {
  id           Int       @id @default(autoincrement())
  supplierId   Int?
  supplierName String    @default("")
  status       String    @default("DRAFT") // DRAFT | ORDERED | RECEIVED | CANCELLED
  items        String    @default("[]") // JSON [{ productId, name, qty, price }]
  total        Float     @default(0)
  note         String    @default("")
  orderedAt    DateTime?
  receivedAt   DateTime?
  createdAt    DateTime  @default(now())
  @@index([status])
}

// A timestamped, authored note staff leave on a customer (allergy, preference…).
model CustomerNote {
  id         String   @id @default(cuid())
  customerId Int
  author     String   @default("")
  body       String
  createdAt  DateTime @default(now())
  @@index([customerId])
}

// End-of-day physical cash reconciliation (one per date).
model CashDrawer {
  id             Int       @id @default(autoincrement())
  date           String    @unique // YYYY-MM-DD
  openingBalance Float     @default(0)
  cashExpenses   Float     @default(0) // cash paid out of the drawer
  refunds        Float     @default(0)
  actualCash     Float     @default(0) // counted at close
  note           String    @default("")
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
}

// A customer's saved package or course (service favourites use Customer.favorites).
model Favorite {
  id         Int      @id @default(autoincrement())
  customerId Int
  kind       String // PACKAGE | COURSE
  itemId     Int
  createdAt  DateTime @default(now())
  @@unique([customerId, kind, itemId])
  @@index([customerId])
}

// Audit trail — who did what in the admin, when, and from where.
model ActivityLog {
  id        Int      @id @default(autoincrement())
  actor     String   @default("") // display name (Owner or staff name)
  staffId   Int? // null = owner master key
  action    String   @default("") // human-readable summary
  detail    String   @default("") // raw method + path
  ip        String   @default("")
  createdAt DateTime @default(now())
  @@index([createdAt])
}

// An image uploaded by the manager (hero, category, gallery, avatars…). Stored
// as bytes so no external file host is needed. Served at GET /api/images/:id.
model Image {
  id        String   @id @default(cuid())
  mime      String
  data      Bytes
  createdAt DateTime @default(now())
}

// A customer review — held for manager moderation, then shown on the site.
model Review {
  id            Int      @id @default(autoincrement())
  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  appointmentId Int?     // optional link, to prevent duplicate reviews per visit
  authorName    String
  rating        Int      @default(5) // 1-5
  comment       String   @default("")
  status        String   @default("PENDING") // PENDING | APPROVED | HIDDEN
  featured      Boolean  @default(false)
  reply         String   @default("") // public owner reply (shown under the review)
  repliedAt     DateTime?
  createdAt     DateTime @default(now())
}

// A running-cost the salon pays (rent, electricity, supplies, salaries…). Used to
// turn gross profit into net profit on the finance dashboard.
model Expense {
  id        Int      @id @default(autoincrement())
  category  String   @default("Other") // Rent | Utilities | Supplies | Marketing | Salaries | Equipment | Other
  label     String   @default("")
  amount    Float    @default(0)
  date      String   // YYYY-MM-DD
  note      String   @default("")
  createdAt DateTime @default(now())
  @@index([date])
}

// A customer waiting for a spot when their preferred time is full.
model WaitlistEntry {
  id            Int      @id @default(autoincrement())
  customerId    Int?
  name          String
  phone         String
  serviceId     Int?
  serviceName   String   @default("")
  staffId       Int?
  staffName     String   @default("")
  preferredDate String   @default("")
  preferredTime String   @default("")
  note          String   @default("")
  status        String   @default("WAITING") // WAITING | CONTACTED | BOOKED | CANCELLED
  createdAt     DateTime @default(now())
  @@index([status])
}

model AddOn {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  price       Float    @default(0)
  durationMin Int      @default(0)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
}

model Staff {
  id            Int      @id @default(autoincrement())
  name          String
  role          String   @default("")
  bio           String   @default("")
  avatar        String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  commissionPct Float    @default(0) // % of service price paid to this staff
  loginEmail    String?  @unique // staff login (set by the manager)
  passwordHash  String? // bcrypt; null = no login yet
  accessRole    String   @default("STAFF") // OWNER | MANAGER | RECEPTIONIST | STAFF (admin access level)
  permissions   String   @default("[]") // JSON array of allowed admin section keys
  // Weekly working schedule: JSON array[7], index 0=Sun..6=Sat,
  // each { off, open, close, breakStart, breakEnd }.
  schedule      String   @default("[]")
  blockedDates  String   @default("[]") // JSON ["YYYY-MM-DD"] — days off / holidays
  services      Service[] @relation("ServiceStaff")
  appointments  Appointment[]
  payouts       Payout[]
  branchId      Int?
  branch        Branch?  @relation(fields: [branchId], references: [id])
}

// A recorded staff payout for a period — the payslip + payout history.
model Payout {
  id               Int      @id @default(autoincrement())
  staffId          Int
  staff            Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  periodFrom       String   // YYYY-MM-DD
  periodTo         String
  appointments     Int      @default(0)
  revenue          Float    @default(0)
  commissionEarned Float    @default(0)
  bonus            Float    @default(0)
  tips             Float    @default(0)
  deduction        Float    @default(0)
  total            Float    @default(0) // commission + bonus + tips − deduction
  note             String   @default("")
  paidAt           DateTime @default(now())
}

model Appointment {
  id               Int      @id @default(autoincrement())
  serviceId        Int?
  service          Service? @relation(fields: [serviceId], references: [id])
  packageId        Int?
  package          Package? @relation(fields: [packageId], references: [id])
  staffId          Int?
  staff            Staff?   @relation(fields: [staffId], references: [id])
  customerId       Int?
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName     String
  customerPhone    String
  customerEmail    String   @default("")
  date             String   // YYYY-MM-DD
  time             String   // HH:MM (start)
  durationMin      Int      @default(30) // total incl. add-ons (scheduled/expected)
  actualMinutes    Int      @default(0) // recorded actual time (0 = not recorded)
  serviceName      String   @default("")
  staffName        String   @default("")
  addOns           String   @default("[]") // JSON [{ name, price }]
  price            Float    @default(0) // total incl. add-ons
  commissionPct    Float    @default(0) // snapshot
  commissionAmount Float    @default(0) // price * pct (staff earnings)
  note             String   @default("")
  promoCode        String   @default("") // discount code applied, if any
  branchId         Int?
  branch           Branch?  @relation(fields: [branchId], references: [id])
  status           String   @default("CONFIRMED") // PENDING | CONFIRMED | CANCELLED | COMPLETED | NO_SHOW
  paymentId        String?  @unique // linked Payment (the money side of this booking)
  paymentMethod    String   @default("CASH") // CASH | WHISH (future: CARD | BANK)
  paymentStatus    String   @default("PENDING") // PENDING | PAID | FAILED | CANCELLED
  stockDeducted    Boolean  @default(false) // inventory already deducted for this visit?
  pointsAwarded    Boolean  @default(false) // loyalty points already granted for this visit?
  createdAt        DateTime @default(now())
  @@index([date])
}
